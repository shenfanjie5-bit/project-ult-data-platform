data_platform:
  target: dev
  outputs:
    dev:
      type: duckdb
      path: "{{ env_var('DP_DUCKDB_PATH', './data_platform/duckdb/data_platform.duckdb') }}"
      extensions: ["iceberg", "httpfs"]
      attach:
        - path: "{{ env_var('DP_PG_DSN', 'postgresql://dp:dp@localhost:5432/data_platform') }}"
          type: postgres
